# Medical Diagnosis API - Environment Configuration

# ============ API SERVER ============
API_HOST=0.0.0.0
API_PORT=8000
API_ENVIRONMENT=development  # or 'production'

# ============ MODEL PATHS ============
MODEL_ENCODER_PATH=encoder_model.keras
MODEL_FULL_PATH=full_model.keras
MODEL_TOKENIZER_PATH=tokenizer.pkl

# ============ IMAGE HANDLING ============
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
ALLOWED_FORMATS=jpg,jpeg,png

# ============ INFERENCE SETTINGS ============
MAX_REPORT_LENGTH=200
IMAGE_MEAN=0.485
IMAGE_STD=0.229
INFERENCE_BATCH_SIZE=1

# ============ PDF SETTINGS ============
PDF_PAGE_SIZE=letter
PDF_TITLE=Medical Diagnostic Report
PDF_INCLUDE_DISCLAIMER=true

# ============ LOGGING ============
LOG_LEVEL=INFO
LOG_FILE=api.log
ENABLE_FILE_LOGGING=false

# ============ CORS SETTINGS ============
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# ============ SECURITY ============
# Set to empty string to disable API key authentication
API_KEY_ENABLED=false
API_KEY_SECRET=your-secret-key-here

# ============ PRODUCTION SETTINGS ============
DEBUG_MODE=false
RELOAD_ON_CHANGES=true
WORKERS=1
